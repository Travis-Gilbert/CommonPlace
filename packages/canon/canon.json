        { "package": "@sigma/edge-curve", "reason": "Sigma edge plugin; cut with sigma." },
        { "package": "react-force-graph-3d", "reason": "Third graph canvas; cosmos.gl is canonical." },
        { "package": "d3-force-3d", "reason": "Force sim for react-force-graph-3d; cut with that stack." }
