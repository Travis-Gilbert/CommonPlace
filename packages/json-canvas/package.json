{
  "name": "@commonplace/json-canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "JSON Canvas 1.0 types, validator, and graph-native interchange for the CommonPlace data canvas (SPEC-DATA-CANVAS-GRAPH-NATIVE-1.0). Pure logic: zero CSS, zero framework imports.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./parse": "./src/parse.ts",
    "./serialize": "./src/serialize.ts",
    "./model": "./src/model.ts",
    "./interchange": "./src/interchange.ts",
    "./colors": "./src/colors.ts",
    "./apply": "./src/apply.ts"
  },
  "scripts": {
    "check": "npx --yes -p typescript@5.7.3 tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^4.1.6"
  }
}
