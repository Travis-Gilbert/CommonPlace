# Copy to .env.local for local development. Do not commit real secrets.

THEOREM_GRAPHQL_URL=http://127.0.0.1:50090
THEOREM_API_KEY=dev-key

# ACP bridge runtime. Railway must provide this executable and workspace mount.
# Chat ACP transport: hosted (default on Railway/production) attaches to the
# Theorem node WebSocket. local/spawn is for desktop and opt-in local-dev.
THEOREM_ACP_TRANSPORT=hosted
THEOREM_ACP_WS_URL=wss://api.theoremharness.com/v1/commonplace/acp/ws
THEOREM_NODE_URL=https://api.theoremharness.com
THEOREM_API_TOKEN=
# Local desktop / opt-in only:
# THEOREM_ACP_TRANSPORT=local
THEOREM_ACP_BIN=/opt/theorem/bin/theorem
THEOREM_ACP_WORKSPACE_MOUNT=/opt/theorem/workspace
THEOREM_ACP_PERMISSION_TIMEOUT_MS=300000

COMMONPLACE_ALLOW_CLIENT_INSTANCE_OVERRIDE=1
COMMONPLACE_CLIENT_INSTANCE_DEFAULT_API_KEY=dev-key

AUTH_SECRET=commonplace-local-dev-only-change-me
AUTH_TRUST_HOST=true
# Operator-only GitHub OAuth app credentials. Product users never configure
# these; they only choose "Sign in with GitHub" in CommonPlace.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: where /v2/work's JSON Canvas boards are persisted (WS4). Defaults
# to apps/web/.data/work-surface/boards when unset. Local filesystem only —
# not durable on a serverless web deployment (see board-store.ts).
# WORK_SURFACE_BOARDS_DIR=
