    "eventsource-parser": "^3.0.0",
    "jotai": "^2.20.2",
    "motion": "^12.35.0",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^3.0.6",
    "tailwind-merge": "^3.6.0",
