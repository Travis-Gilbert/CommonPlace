# commonplace-api voice configuration (STT + TTS).
#
# Copy to `.env`, fill in real values, and source it before `npm run api:dev`:
#   set -a && source apps/commonplace-api/.env && set +a
# The server reads process env; it does NOT auto-load this file. `.env` is
# gitignored; only this `.env.example` template (placeholders) is committed.
#
# SECURITY: never paste a real key into chat, code, or a commit. If a key is
# ever exposed, rotate it at the provider dashboard and put the new value ONLY
# in the local `.env`.

# --- Speech-to-text (voice capture -> transcript). Unset = audio stored as-is. ---
# Provider: "whisper" (self-hosted OpenAI-compatible) or "elevenlabs" (Scribe).
COMMONPLACE_STT_PROVIDER=elevenlabs
# Self-hosted Whisper node (OpenAI /v1/audio/transcriptions). Used when provider=whisper.
WHISPER_STT_URL=http://127.0.0.1:8080/v1/audio/transcriptions
WHISPER_STT_MODEL=whisper-1
# ElevenLabs Scribe model. Used when provider=elevenlabs.
ELEVENLABS_STT_MODEL=scribe_v1

# --- Text-to-speech (answer read-back). Default provider = elevenlabs. ---
# Provider: "elevenlabs" (hosted) or "kokoro" (self-hosted, OpenAI-compatible).
COMMONPLACE_TTS_PROVIDER=elevenlabs
ELEVENLABS_TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
# Self-hosted Kokoro node (e.g. kokoro-fastapi /v1/audio/speech). Used when provider=kokoro.
