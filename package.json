{
  "name": "@commonplace/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:rustyred": "node scripts/update-rustyred-source.mjs",
    "install:railway": "npm --prefix apps/web ci --legacy-peer-deps --workspaces=false && mkdir -p node_modules && touch node_modules/.railpack-keep",
    "build:railway": "npm run install:railway && npm --prefix apps/web run build:railway",
    "start:railway": "npm --prefix apps/web run start:railway",
    "mobile:start": "npm --prefix apps/mobile run start",
    "mobile:check": "npm --prefix apps/mobile exec tsc -- --noEmit",
    "web:dev": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:build:desktop": "npm --prefix apps/web run build:desktop",
    "desktop:dev": "npm --prefix apps/desktop run tauri -- dev",
    "desktop:build": "npm --prefix apps/desktop run tauri -- build",
    "collab:dev": "npm --prefix apps/commonplace-collab run dev",
    "collab:start": "npm --prefix apps/commonplace-collab run start",
    "api:dev": "cargo run --manifest-path apps/commonplace-api/Cargo.toml",
    "api:test": "cargo test --manifest-path apps/commonplace-api/Cargo.toml",
    "check": "node scripts/update-rustyred-source.mjs --check && cargo test --workspace && npm --prefix packages/block-view-contracts run check",
    "check:rust": "cargo test --workspace"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@blocksuite/icons": "2.1.75"
    }
  }
}
